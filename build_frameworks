#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SOURCE_ROOT="$SCRIPT_DIR"
BUILD_ROOT="$SCRIPT_DIR/build-xcf"
OUTPUT="$SCRIPT_DIR/lib/libastap.xcframework"
LIB_NAME="libastap_lib.a"

if [[ -d "$BUILD_ROOT" ]]; then
	mv "$BUILD_ROOT" "$BUILD_ROOT.old.$$"
	rm -rf "$BUILD_ROOT.old.$$" &
fi
mkdir -p "$BUILD_ROOT" "$SCRIPT_DIR/lib"

# ---------- per-SDK build ----------------------------------------------------

build_one() {
	local sdk="$1" arch="$2" system_name="$3"
	local tag="${sdk}-${arch}"
	local build_dir="$BUILD_ROOT/$tag"
	local install_dir="$build_dir/install"
	local sdk_path
	sdk_path="$(xcrun --sdk "$sdk" --show-sdk-path)"

	cmake -S "$SOURCE_ROOT" -B "$build_dir" \
		-DCMAKE_SYSTEM_NAME="$system_name" \
		-DCMAKE_OSX_SYSROOT="$sdk_path" \
		-DCMAKE_OSX_ARCHITECTURES="$arch" \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX="$install_dir" \
		-DBUILD_SHARED_LIBS=OFF \
		-DASTAP_BUILD_CLI=OFF

	cmake --build "$build_dir" --config Release --target install --parallel
}

# ---------- build all platforms ----------------------------------------------

build_one iphoneos        arm64   iOS
build_one iphonesimulator arm64   iOS
build_one xros            arm64   visionOS
build_one xrsimulator     arm64   visionOS
build_one watchos         arm64   watchOS
build_one watchsimulator  arm64   watchOS
build_one macosx          arm64   Darwin
build_one macosx          x86_64  Darwin

# ---------- macOS universal binary -------------------------------------------

MACOS_UNIV="$BUILD_ROOT/macosx-universal"
mkdir -p "$MACOS_UNIV/lib" "$MACOS_UNIV/include"

lipo -create \
	"$BUILD_ROOT/macosx-arm64/install/lib/$LIB_NAME" \
	"$BUILD_ROOT/macosx-x86_64/install/lib/$LIB_NAME" \
	-output "$MACOS_UNIV/lib/$LIB_NAME"

rsync -a "$BUILD_ROOT/macosx-arm64/install/include/" "$MACOS_UNIV/include/"

# ---------- assemble xcframework ---------------------------------------------

rm -rf "$OUTPUT"

xcodebuild -create-xcframework \
	-library "$BUILD_ROOT/iphoneos-arm64/install/lib/$LIB_NAME" \
	-headers "$BUILD_ROOT/iphoneos-arm64/install/include" \
	-library "$BUILD_ROOT/iphonesimulator-arm64/install/lib/$LIB_NAME" \
	-headers "$BUILD_ROOT/iphonesimulator-arm64/install/include" \
	-library "$BUILD_ROOT/xros-arm64/install/lib/$LIB_NAME" \
	-headers "$BUILD_ROOT/xros-arm64/install/include" \
	-library "$BUILD_ROOT/xrsimulator-arm64/install/lib/$LIB_NAME" \
	-headers "$BUILD_ROOT/xrsimulator-arm64/install/include" \
	-library "$BUILD_ROOT/watchos-arm64/install/lib/$LIB_NAME" \
	-headers "$BUILD_ROOT/watchos-arm64/install/include" \
	-library "$BUILD_ROOT/watchsimulator-arm64/install/lib/$LIB_NAME" \
	-headers "$BUILD_ROOT/watchsimulator-arm64/install/include" \
	-library "$MACOS_UNIV/lib/$LIB_NAME" \
	-headers "$MACOS_UNIV/include" \
	-output "$OUTPUT"

echo "Wrote $OUTPUT"
